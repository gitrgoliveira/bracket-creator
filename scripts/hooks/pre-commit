#!/usr/bin/env bash
#
# Fast pre-commit gate for bracket-creator.
# Tracked in scripts/hooks/ and wired up via core.hooksPath=scripts/hooks
# (set by `make hooks/install`, which is also run from `make local/deps`).
#
# Goal: catch the cheap, high-frequency breakages (bad gofmt, compile/vet
# errors) BEFORE a commit — and therefore before Copilot/CI — without paying
# the cost of the full `make go/test` (lint + security scan + JS suite) on
# every commit. Run that heavier gate before pushing instead.
#
# Bypass once with:  git commit --no-verify
set -euo pipefail

# Only check Go when Go files are staged. Skip vendored/generated paths.
staged_go=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' \
  | grep -v '^vendor/' || true)

if [ -z "$staged_go" ]; then
  exit 0
fi

if ! command -v go >/dev/null 2>&1; then
  echo "pre-commit: 'go' not found on PATH — skipping Go checks." >&2
  exit 0
fi

fail=0

# 1) Formatting — flag (do not auto-rewrite) any staged file gofmt would change.
unformatted=$(gofmt -l $staged_go || true)
if [ -n "$unformatted" ]; then
  echo "pre-commit: gofmt would reformat these staged files:" >&2
  echo "$unformatted" | sed 's/^/  /' >&2
  echo "  fix with: gofmt -w <files>  (or: make go/fmt)" >&2
  fail=1
fi

# Ensure the gitignored //go:embed build-info stubs exist. They are generated
# only at build time (internal/cmd/version/get_build_info.sh); without them
# `go vet ./...` fails to compile the version package on a fresh worktree,
# which would falsely block every commit. Empty placeholders satisfy the embed
# directive and are regenerated by the real build; they are gitignored so they
# never enter a commit.
repo_root=$(git rev-parse --show-toplevel)
for stub in commit.txt version.txt build_date.txt; do
  f="$repo_root/internal/cmd/version/$stub"
  [ -e "$f" ] || : > "$f"
done

# 2) Vet — type-checks + common-bug analysis across all packages (compiles, so
#    this also catches build breakage). Cache makes the steady-state run fast.
if ! go vet ./... ; then
  echo "pre-commit: 'go vet ./...' failed — fix the above before committing." >&2
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "pre-commit gate failed. Re-run after fixing, or bypass with: git commit --no-verify" >&2
  echo "(The full gate — lint + security + JS — still runs via 'make go/test' before push.)" >&2
  exit 1
fi

exit 0
